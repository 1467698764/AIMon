{
  "name": "aimon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"tsx watch server/index.ts\"",
    "build": "tsc -p server/tsconfig.json && vite build",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run && tsx tests/site-service-integration.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cloakbrowser": "^0.4.12",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "playwright-core": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
