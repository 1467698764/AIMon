PORT=8787
DATA_DIR=./data
AIMON_SECRET=replace-with-at-least-32-random-characters
REQUEST_TIMEOUT_MS=30000
HEALTH_ATTEMPTS=3
# 可选的第二层 HTTP Basic Auth；留空时只使用页面内管理密码
AIMON_BASIC_USER=
AIMON_BASIC_PASSWORD=
CLOAKBROWSER_ENABLED=true
CLOAKBROWSER_HEADLESS=true
CLOAKBROWSER_TIMEOUT_MS=60000
CLOAKBROWSER_IDLE_MS=180000
CLOAKBROWSER_MAX_CONTEXTS=2
# Optional HTTP/SOCKS5 proxy. Treat this value as a secret when it contains credentials.
CLOAKBROWSER_PROXY=
# Optional local Chrome/Chromium path used when the dedicated binary cannot be downloaded.
CLOAKBROWSER_BINARY_PATH=
CLOAKBROWSER_AUTO_UPDATE=false
